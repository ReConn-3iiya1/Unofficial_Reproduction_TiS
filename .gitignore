# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
eggs/
*.egg-info/
*.egg

# Virtual environments
env/
.venv/
venv/
ENV/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Pytest cache
.pytest_cache/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store

# Encrypted environment files
.env
.env.*

# Data, models and outputs (do not track large binary files)
data/raw/
data/processed/
data/splits/
outputs/
models/
outputs/models/
*.ckpt
*.pth
*.pt

# Logs
*.log

# Ignore local config files
configs/local.yaml
